# Copia questo file in .env e compila i valori (NON committare .env su GitHub)

# Flask
SECRET_KEY=cambia-questa-stringa-con-qualcosa-di-casuale-e-lungo
FLASK_ENV=development
PREFERRED_URL_SCHEME=http
ENABLE_PROXY_FIX=1
FORCE_HTTPS_COOKIES=0
AUTO_DB_BOOTSTRAP=1

# Sicurezza cookie / host
SESSION_COOKIE_SAMESITE=Lax
REMEMBER_COOKIE_SAMESITE=Lax
TRUSTED_HOSTS=

# Database: SQLite per sviluppo locale, PostgreSQL in produzione
# Per locale, lascia vuoto — userà SQLite automaticamente
DATABASE_URL=

# Brevo (per invio email)
BREVO_API_KEY=la-tua-api-key-brevo

# Email mittente (deve corrispondere al dominio verificato su Brevo)
MAIL_SENDER=a.venticinque@logimetric.eu

# Email admin (questo account avrà ruolo admin automaticamente al primo login)
ADMIN_EMAIL=a.venticinque@logimetric.eu

# Task Manager
TASKS_API_KEY=chiave-segreta-per-power-automate
CRON_SECRET=chiave-segreta-per-cron-job-org

# Power App (link diretto — copialo da Power Apps → File → Dettagli → Link Web)
POWERAPP_URL=https://apps.powerapps.com/play/e/xxx/a/xxx
POWERAPP_TASK_ID_PARAM=task_id

# Rate limiting base
LOGIN_RATE_LIMIT_ATTEMPTS=8
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
RESET_RATE_LIMIT_ATTEMPTS=5
RESET_RATE_LIMIT_WINDOW_SECONDS=3600

# Telegram notifiche task
TELEGRAM_ENABLED=0
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
APP_BASE_URL=https://logimetric.eu
